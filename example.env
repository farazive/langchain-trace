# Copy to .env and fill in. .env is gitignored.

# Set to false to make real Claude API calls. Requires ANTHROPIC_API_KEY below.
# Left true by default so a fresh clone runs with no key and no spend.
USE_FAKE_LLM=false

# Required only when USE_FAKE_LLM=false. Get one from console.anthropic.com.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# OpenLLMetry records prompt and completion text as span attributes by default,
# which is what makes the traces readable in Jaeger. Set to false when chat
# content should not reach the trace backend.
# TRACELOOP_TRACE_CONTENT=false

# Added during streaming work
EXCLUDE_ASGI_SPANS=false
